{
  "id": "06-reset-password",
  "level": 6,
  "title": "Reset a Password",
  "category": "network",
  "categoryLabel": "Active Directory",
  "points": 300,
  "description": "Welcome to Rank Challenge. The user `jdoe` is locked out and needs a fresh password. Reset their account password to a new secure value using `Set-ADAccountPassword` with a secure string.",
  "objectives": [
    "Reset the account password with Set-ADAccountPassword",
    "Supply the new password as a secure string"
  ],
  "hints": [
    "Use Set-ADAccountPassword with the -Reset switch.",
    "Wrap the new value with ConvertTo-SecureString and pass it to -NewPassword."
  ],
  "hintPenalty": 15,
  "validationType": "text-match",
  "files": [
    {
      "filename": "task.ps1",
      "language": "powershell",
      "editable": true,
      "content": "# TODO: give this account a brand new sign-in secret so they can get back in\nSet-ADAccountPassword -Identity jdoe"
    }
  ],
  "validation": {
    "parseRules": [
      {
        "rule": "contains-string",
        "value": "Set-ADAccountPassword",
        "ignoreCase": true,
        "failMessage": "Use Set-ADAccountPassword.",
        "description": "Resets the password"
      },
      {
        "rule": "regex",
        "pattern": "-Reset",
        "flags": "i",
        "failMessage": "Reset it with the -Reset switch.",
        "description": "Uses -Reset"
      },
      {
        "rule": "regex",
        "pattern": "-NewPassword",
        "flags": "i",
        "failMessage": "Supply the new value with -NewPassword.",
        "description": "Provides a new password"
      },
      {
        "rule": "contains-string",
        "value": "ConvertTo-SecureString",
        "ignoreCase": true,
        "failMessage": "Build the value with ConvertTo-SecureString.",
        "description": "Uses a secure string"
      }
    ]
  },
  "previewConfig": {
    "type": "console"
  },
  "unlockRequires": [
    "05-firewall-enable-rule"
  ]
}
