{
  "id": "07-password-policy",
  "level": 7,
  "title": "Harden the Password Policy",
  "category": "network",
  "categoryLabel": "Active Directory",
  "points": 300,
  "description": "Welcome to Rank Challenge. Security wants stronger passwords domain-wide. Update the default domain password policy for `corp.local` so the minimum length is `14` and complexity is enabled.",
  "objectives": [
    "Update the default domain password policy",
    "Set a minimum length and enable complexity"
  ],
  "hints": [
    "Set-ADDefaultDomainPasswordPolicy changes the domain-wide rules.",
    "Use -MinPasswordLength and -ComplexityEnabled $true."
  ],
  "hintPenalty": 15,
  "validationType": "text-match",
  "files": [
    {
      "filename": "task.ps1",
      "language": "powershell",
      "editable": true,
      "content": "# TODO: harden the domain-wide sign-in rules: longer secrets and stricter make-up\nSet-ADDefaultDomainPasswordPolicy -Identity corp.local"
    }
  ],
  "validation": {
    "parseRules": [
      {
        "rule": "contains-string",
        "value": "Set-ADDefaultDomainPasswordPolicy",
        "ignoreCase": true,
        "failMessage": "Use Set-ADDefaultDomainPasswordPolicy.",
        "description": "Edits the domain policy"
      },
      {
        "rule": "regex",
        "pattern": "-MinPasswordLength",
        "flags": "i",
        "failMessage": "Set the minimum length with -MinPasswordLength.",
        "description": "Sets minimum length"
      },
      {
        "rule": "regex",
        "pattern": "-ComplexityEnabled",
        "flags": "i",
        "failMessage": "Require complexity with -ComplexityEnabled.",
        "description": "Enables complexity"
      }
    ]
  },
  "previewConfig": {
    "type": "console"
  },
  "unlockRequires": [
    "06-reset-password"
  ]
}
